# Copy this file to ".env" in the same folder as package.json, then fill in values.
# Supabase: Dashboard → your project → Project Settings → API
#   - Project URL     → REACT_APP_SUPABASE_URL
#   - anon public key → REACT_APP_SUPABASE_ANON_KEY
# Mapbox (Map screen): https://account.mapbox.com/access-tokens/ — default public token (pk.…)
#   - REACT_APP_MAPBOX_TOKEN
#
# After saving .env, stop the terminal (Ctrl+C) and run: npm start
#
# Optional local testing: open http://localhost:3000/?devWelcome=1 once to clear session and land on login.

REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
