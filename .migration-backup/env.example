# React app (optional): set to "true" to always show welcome screen and ignore saved session (dev only)
# REACT_APP_ALWAYS_SHOW_WELCOME=true
#
# By default, only a real Supabase Auth session skips the welcome + login flow.
# Set to "true" to also skip welcome when a mock user exists in localStorage (old behavior).
# REACT_APP_RESTORE_LOCAL_USER_SESSION=true
#
# Optional test-only signup email overrides (comma-separated):
# REACT_APP_EXTRA_ALLOWED_SIGNUP_EMAILS=you@me.com
# REACT_APP_EXTRA_ALLOWED_SIGNUP_DOMAINS=me.com

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration (allow your app to send data)
CORS_ORIGIN=http://localhost:3000

# API Key for app authentication (optional security)
API_KEY=your-secret-api-key-for-app-communication

# Mapbox Configuration
# Get your token from: https://account.mapbox.com/access-tokens/
# Use your Default public token (starts with pk.)
REACT_APP_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000 